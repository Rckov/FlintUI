<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:ct="clr-namespace:FlintUI.Controls">

    <Style TargetType="{x:Type ct:PasswordBox}">
        <Setter Property="Background" Value="{DynamicResource ControlBackground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
        <Setter Property="Foreground" Value="{DynamicResource Foreground}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FontSize" Value="{DynamicResource FontSize.S}" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ct:PasswordBox}">
                    <Border x:Name="PART_Border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{DynamicResource Radius.S}"
                            Padding="{DynamicResource Spacing.M.Vertical}">
                        <Grid Margin="{DynamicResource Spacing.M.Horizontal}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Grid Grid.Column="0">
                                <TextBlock x:Name="PART_Placeholder"
                                           Text="{TemplateBinding Placeholder}"
                                           Foreground="{DynamicResource Foreground.Muted}"
                                           FontSize="{TemplateBinding FontSize}"
                                           VerticalAlignment="Center"
                                           IsHitTestVisible="False" />

                                <PasswordBox x:Name="PART_PasswordBox"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Padding="0"
                                             Foreground="{TemplateBinding Foreground}"
                                             CaretBrush="{TemplateBinding Foreground}"
                                             FontSize="{TemplateBinding FontSize}"
                                             VerticalContentAlignment="Center" />

                                <TextBox x:Name="PART_TextBox"
                                         Text="{Binding Password, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Padding="0"
                                         Foreground="{TemplateBinding Foreground}"
                                         CaretBrush="{TemplateBinding Foreground}"
                                         FontSize="{TemplateBinding FontSize}"
                                         VerticalContentAlignment="Center"
                                         Visibility="Collapsed" />
                            </Grid>

                            <ToggleButton x:Name="PART_ToggleButton"
                                          Grid.Column="1"
                                          IsChecked="{Binding ShowPassword, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          Width="16"
                                          Height="16"
                                          Margin="{DynamicResource Spacing.M.Left}"
                                          Focusable="False"
                                          Cursor="Hand"
                                          VerticalAlignment="Center">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                                        <Border x:Name="Border"
                                                Background="Transparent"
                                                CornerRadius="{DynamicResource Radius.X}">
                                            <ct:Icon x:Name="Icon"
                                                     Kind="Eye"
                                                     Size="12"
                                                     Foreground="{DynamicResource Foreground.Muted}" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Border" Property="Background"
                                                        Value="{DynamicResource Overlay.Hover}" />
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="Icon" Property="Kind" Value="EyeOff" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="ShowPassword" Value="True">
                            <Setter TargetName="PART_PasswordBox" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="PART_TextBox" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="HasText" Value="True">
                            <Setter TargetName="PART_Placeholder" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="RevealButton" Value="False">
                            <Setter TargetName="PART_ToggleButton" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="PART_Border" Property="BorderBrush" Value="{DynamicResource Accent}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>