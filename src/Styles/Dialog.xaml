<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:ct="clr-namespace:FlintUI.Controls">

    <Style TargetType="{x:Type ct:DialogWindow}">
        <Setter Property="Foreground" Value="{DynamicResource Foreground}" />
        <Setter Property="FontSize" Value="{DynamicResource FontSize.M}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ct:DialogWindow}">
                    <Border MinWidth="320"
                            MaxWidth="520"
                            Background="{DynamicResource ControlBackground}"
                            BorderBrush="{DynamicResource Border}"
                            BorderThickness="1"
                            CornerRadius="{DynamicResource Radius.M}"
                            Padding="{DynamicResource Spacing.L}"
                            Effect="{DynamicResource Shadow.M}">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel x:Name="PART_Header" Grid.Row="0" Orientation="Horizontal">
                                <ct:Icon x:Name="DialogIcon"
                                         Size="20"
                                         VerticalAlignment="Top"
                                         Visibility="Collapsed"
                                         Margin="{DynamicResource Spacing.M.Right}" />

                                <TextBlock x:Name="CaptionText"
                                           Text="{TemplateBinding Caption}"
                                           FontSize="{DynamicResource FontSize.L}"
                                           FontWeight="{DynamicResource FontWeight.SemiBold}"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Center" />
                            </StackPanel>

                            <TextBlock Grid.Row="1"
                                       Margin="{DynamicResource Spacing.L.Vertical}"
                                       Text="{TemplateBinding Message}"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource Foreground.Muted}" />

                            <StackPanel Grid.Row="2"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Right">

                                <ct:Button x:Name="PART_Cancel"
                                           Content="{DynamicResource Dialog.Cancel}"
                                           ButtonKind="Default"
                                           IsCancel="True"
                                           Visibility="Collapsed" />

                                <ct:Button x:Name="PART_No"
                                           Content="{DynamicResource Dialog.No}"
                                           ButtonKind="Default"
                                           Visibility="Collapsed"
                                           Margin="{DynamicResource Spacing.S.Left}" />

                                <ct:Button x:Name="PART_Yes"
                                           Content="{DynamicResource Dialog.Yes}"
                                           ButtonKind="Accent"
                                           IsDefault="True"
                                           Visibility="Collapsed"
                                           Margin="{DynamicResource Spacing.S.Left}" />

                                <ct:Button x:Name="PART_Ok"
                                           Content="{DynamicResource Dialog.Ok}"
                                           ButtonKind="Accent"
                                           IsDefault="True"
                                           Visibility="Collapsed"
                                           Margin="{DynamicResource Spacing.S.Left}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <ControlTemplate.Triggers>

                        <Trigger Property="Caption" Value="">
                            <Setter TargetName="CaptionText" Property="Visibility" Value="Collapsed" />
                        </Trigger>

                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="Caption" Value="" />
                                <Condition Property="Symbol" Value="None" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="PART_Header" Property="Visibility" Value="Collapsed" />
                        </MultiTrigger>

                        <Trigger Property="Buttons" Value="Ok">
                            <Setter TargetName="PART_Ok" Property="Visibility" Value="Visible" />
                        </Trigger>

                        <Trigger Property="Buttons" Value="OkCancel">
                            <Setter TargetName="PART_Ok" Property="Visibility" Value="Visible" />
                            <Setter TargetName="PART_Cancel" Property="Visibility" Value="Visible" />
                        </Trigger>

                        <Trigger Property="Buttons" Value="YesNo">
                            <Setter TargetName="PART_Yes" Property="Visibility" Value="Visible" />
                            <Setter TargetName="PART_No" Property="Visibility" Value="Visible" />
                            <Setter TargetName="PART_No" Property="IsCancel" Value="True" />
                        </Trigger>

                        <Trigger Property="Buttons" Value="YesNoCancel">
                            <Setter TargetName="PART_Yes" Property="Visibility" Value="Visible" />
                            <Setter TargetName="PART_No" Property="Visibility" Value="Visible" />
                            <Setter TargetName="PART_Cancel" Property="Visibility" Value="Visible" />
                        </Trigger>

                        <Trigger Property="Symbol" Value="Info">
                            <Setter TargetName="DialogIcon" Property="Visibility" Value="Visible" />
                            <Setter TargetName="DialogIcon" Property="Kind" Value="Info" />
                            <Setter TargetName="DialogIcon" Property="Foreground" Value="{DynamicResource Accent}" />
                        </Trigger>

                        <Trigger Property="Symbol" Value="Success">
                            <Setter TargetName="DialogIcon" Property="Visibility" Value="Visible" />
                            <Setter TargetName="DialogIcon" Property="Kind" Value="CheckCircle" />
                            <Setter TargetName="DialogIcon" Property="Foreground" Value="{DynamicResource Success}" />
                        </Trigger>

                        <Trigger Property="Symbol" Value="Warning">
                            <Setter TargetName="DialogIcon" Property="Visibility" Value="Visible" />
                            <Setter TargetName="DialogIcon" Property="Kind" Value="Warning" />
                            <Setter TargetName="DialogIcon" Property="Foreground" Value="{DynamicResource Warning}" />
                        </Trigger>

                        <Trigger Property="Symbol" Value="Error">
                            <Setter TargetName="DialogIcon" Property="Visibility" Value="Visible" />
                            <Setter TargetName="DialogIcon" Property="Kind" Value="XCircle" />
                            <Setter TargetName="DialogIcon" Property="Foreground" Value="{DynamicResource Danger}" />
                        </Trigger>

                        <Trigger Property="Symbol" Value="Question">
                            <Setter TargetName="DialogIcon" Property="Visibility" Value="Visible" />
                            <Setter TargetName="DialogIcon" Property="Kind" Value="HelpCircle" />
                            <Setter TargetName="DialogIcon" Property="Foreground" Value="{DynamicResource Accent}" />
                        </Trigger>

                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>