<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:ct="clr-namespace:FlintUI.Controls">

    <Style TargetType="{x:Type ct:TextBox}">
        <Setter Property="Background" Value="{DynamicResource ControlBackground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
        <Setter Property="Foreground" Value="{DynamicResource Foreground}" />
        <Setter Property="CaretBrush" Value="{DynamicResource Foreground}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FontSize" Value="{DynamicResource FontSize.S}" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Validation.ErrorTemplate" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ct:TextBox}">
                    <StackPanel>
                        <Border x:Name="PART_Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{DynamicResource Radius.S}"
                                Padding="{DynamicResource Spacing.M.Vertical}">
                            <Grid Margin="{DynamicResource Spacing.M.Horizontal}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <ct:Icon x:Name="PART_Icon"
                                         Grid.Column="0"
                                         Kind="{TemplateBinding IconKind}"
                                         Size="13"
                                         Foreground="{DynamicResource Foreground.Muted}"
                                         Margin="{DynamicResource Spacing.M.Right}"
                                         VerticalAlignment="Center" />

                                <Grid Grid.Column="1">
                                    <TextBlock x:Name="PART_Placeholder"
                                               Text="{TemplateBinding Placeholder}"
                                               Foreground="{DynamicResource Foreground.Muted}"
                                               FontSize="{TemplateBinding FontSize}"
                                               VerticalAlignment="Center"
                                               IsHitTestVisible="False" />
                                    <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center" />
                                </Grid>

                                <Button x:Name="PART_ClearButton"
                                        Grid.Column="2"
                                        Width="16"
                                        Height="16"
                                        Margin="{DynamicResource Spacing.M.Left}"
                                        Padding="0"
                                        Focusable="False"
                                        FocusVisualStyle="{x:Null}"
                                        Cursor="Hand"
                                        VerticalAlignment="Center"
                                        Visibility="Collapsed">
                                    <Button.Template>
                                        <ControlTemplate TargetType="{x:Type Button}">
                                            <Border x:Name="Border"
                                                    Background="Transparent"
                                                    CornerRadius="{DynamicResource Radius.X}">
                                                <ct:Icon Kind="X"
                                                         Size="8"
                                                         Foreground="{DynamicResource Foreground.Muted}" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Border" Property="Background" Value="{DynamicResource Overlay.Hover}" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>
                        </Border>
                        <TextBlock x:Name="PART_ErrorText"
                                   Text="{Binding (Validation.Errors)[0].ErrorContent.ErrorMessage, RelativeSource={RelativeSource TemplatedParent}}"
                                   Foreground="{DynamicResource Danger}"
                                   FontSize="{DynamicResource FontSize.X}"
                                   Margin="{DynamicResource Spacing.S}"
                                   Visibility="Collapsed" />
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="HasIcon" Value="False">
                            <Setter TargetName="PART_Icon" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="HasText" Value="True">
                            <Setter TargetName="PART_Placeholder" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="ClearButton" Value="True" />
                                <Condition Property="HasText" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="PART_ClearButton" Property="Visibility" Value="Visible" />
                        </MultiTrigger>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="PART_Border" Property="BorderBrush" Value="{DynamicResource Accent}" />
                        </Trigger>
                        <Trigger Property="Validation.HasError" Value="True">
                            <Setter TargetName="PART_Border" Property="BorderBrush" Value="{DynamicResource Danger}" />
                            <Setter TargetName="PART_Border" Property="Background" Value="{DynamicResource Danger.Background}" />
                            <Setter TargetName="PART_ErrorText" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>