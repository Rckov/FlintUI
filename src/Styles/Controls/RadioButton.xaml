<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style TargetType="{x:Type RadioButton}">
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="FontSize" Value="{DynamicResource FontSize.M}" />
        <Setter Property="Foreground" Value="{DynamicResource Foreground}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type RadioButton}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border x:Name="Indicator"
                                Width="16"
                                Height="16"
                                CornerRadius="{DynamicResource Radius.Full}"
                                Background="{DynamicResource ControlBackground}"
                                BorderBrush="{DynamicResource Border}"
                                BorderThickness="1">
                            <Ellipse x:Name="Dot"
                                     Width="7"
                                     Height="7"
                                     Fill="White"
                                     Visibility="Collapsed" />
                        </Border>
                        <ContentPresenter x:Name="Content"
                                          VerticalAlignment="Center"
                                          RecognizesAccessKey="True" />
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="HasContent" Value="True">
                            <Setter TargetName="Content" Property="Margin" Value="{DynamicResource Spacing.M.Left}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Indicator" Property="Background" Value="{DynamicResource Accent}" />
                            <Setter TargetName="Indicator" Property="BorderBrush" Value="{DynamicResource Accent}" />
                            <Setter TargetName="Dot" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True" />
                                <Condition Property="IsChecked" Value="False" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Indicator" Property="BorderBrush"
                                    Value="{DynamicResource Border.Hover}" />
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True" />
                                <Condition Property="IsChecked" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Indicator" Property="Background" Value="{DynamicResource Accent.Hover}" />
                            <Setter TargetName="Indicator" Property="BorderBrush"
                                    Value="{DynamicResource Accent.Hover}" />
                        </MultiTrigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>