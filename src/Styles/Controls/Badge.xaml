<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:ct="clr-namespace:FlintUI.Controls">

    <Style TargetType="{x:Type ct:Badge}">
        <Setter Property="FontSize" Value="{DynamicResource FontSize.S}" />
        <Setter Property="Foreground" Value="{DynamicResource Foreground.Muted}" />
        <Setter Property="FontWeight" Value="{DynamicResource FontWeight.Medium}" />
        <Setter Property="Padding" Value="{DynamicResource Spacing.S}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Background" Value="{DynamicResource Border}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ct:Badge}">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{DynamicResource Radius.X}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="BadgeType" Value="Accent">
                <Setter Property="Background" Value="{DynamicResource Accent.Dim}" />
                <Setter Property="Foreground" Value="{DynamicResource Accent}" />
                <Setter Property="BorderThickness" Value="0" />
            </Trigger>
            <Trigger Property="BadgeType" Value="Success">
                <Setter Property="Background" Value="{DynamicResource Success.Background}" />
                <Setter Property="BorderBrush" Value="{DynamicResource Success.Border}" />
                <Setter Property="Foreground" Value="{DynamicResource Success.Foreground}" />
            </Trigger>
            <Trigger Property="BadgeType" Value="Warning">
                <Setter Property="Background" Value="{DynamicResource Warning.Background}" />
                <Setter Property="BorderBrush" Value="{DynamicResource Warning.Border}" />
                <Setter Property="Foreground" Value="{DynamicResource Warning.Foreground}" />
            </Trigger>
            <Trigger Property="BadgeType" Value="Danger">
                <Setter Property="Background" Value="{DynamicResource Danger.Background}" />
                <Setter Property="BorderBrush" Value="{DynamicResource Danger.Border}" />
                <Setter Property="Foreground" Value="{DynamicResource Danger}" />
            </Trigger>
        </Style.Triggers>
    </Style>
</ResourceDictionary>