<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <DropShadowEffect x:Key="Shadow.S"
                      BlurRadius="4"  ShadowDepth="1" Direction="270"
                      Color="#000000" Opacity="0.06" RenderingBias="Quality" />

    <DropShadowEffect x:Key="Shadow.M"
                      BlurRadius="16" ShadowDepth="3" Direction="270"
                      Color="#000000" Opacity="0.10" RenderingBias="Quality" />

    <DropShadowEffect x:Key="Shadow.L"
                      BlurRadius="32" ShadowDepth="6" Direction="270"
                      Color="#000000" Opacity="0.15" RenderingBias="Quality" />
</ResourceDictionary>