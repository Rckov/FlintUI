<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:ct="clr-namespace:FlintUI.Controls">

    <ControlTemplate x:Key="WindowButtonTemplate" TargetType="{x:Type Button}">
        <Border x:Name="Border" Background="{TemplateBinding Background}">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>

        <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Border" Property="Background" Value="{DynamicResource Border}" />
            </Trigger>

            <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Border" Property="Background" Value="{DynamicResource Border.Hover}" />
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <ControlTemplate x:Key="WindowCloseButtonTemplate" TargetType="{x:Type Button}">
        <Border x:Name="Border" Background="{TemplateBinding Background}">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>

        <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Border" Property="Background" Value="{DynamicResource Danger}" />
            </Trigger>

            <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Border" Property="Background" Value="{DynamicResource Danger.Hover}" />
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <Style x:Key="BaseWindowButton" TargetType="{x:Type Button}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>

    <Style x:Key="WindowButton" TargetType="{x:Type Button}" BasedOn="{StaticResource BaseWindowButton}">
        <Setter Property="Template" Value="{StaticResource WindowButtonTemplate}" />
    </Style>

    <Style x:Key="WindowCloseButton" TargetType="{x:Type Button}" BasedOn="{StaticResource BaseWindowButton}">
        <Setter Property="Template" Value="{StaticResource WindowCloseButtonTemplate}" />
    </Style>

    <Style TargetType="{x:Type ct:Window}">
        <Setter Property="Background" Value="{DynamicResource Background}" />
        <Setter Property="Foreground" Value="{DynamicResource Foreground}" />
        <Setter Property="WindowStyle" Value="SingleBorderWindow" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ct:Window}">
                    <Border x:Name="PART_Root" Background="{DynamicResource Background}"
                            BorderBrush="{DynamicResource Border}" BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="40" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Background="{DynamicResource PanelBackground}"
                                    BorderBrush="{DynamicResource Border}" BorderThickness="0,0,0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center"
                                                Margin="{DynamicResource Spacing.L.Left}">
                                        <Image x:Name="PART_Icon"
                                               Height="16"
                                               Width="16"
                                               Stretch="Uniform"
                                               Margin="{DynamicResource Spacing.S.Right}"
                                               Source="{TemplateBinding Icon}" />

                                        <TextBlock Text="{TemplateBinding Title}"
                                                   FontSize="{DynamicResource FontSize.M}"
                                                   Foreground="{DynamicResource Foreground}"
                                                   VerticalAlignment="Center" />

                                        <TextBlock x:Name="PART_Separator"
                                                   Text=" › "
                                                   FontSize="{DynamicResource FontSize.M}"
                                                   Foreground="{DynamicResource Foreground.Muted}"
                                                   VerticalAlignment="Center"
                                                   Visibility="Collapsed" />

                                        <TextBlock x:Name="PART_Subtitle"
                                                   Text="{TemplateBinding Subtitle}"
                                                   FontSize="{DynamicResource FontSize.M}"
                                                   Foreground="{DynamicResource Foreground.Muted}"
                                                   VerticalAlignment="Center"
                                                   Visibility="Collapsed" />
                                    </StackPanel>

                                    <ContentPresenter Grid.Column="1" Content="{TemplateBinding LeftContent}" />

                                    <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right"
                                                WindowChrome.IsHitTestVisibleInChrome="True">
                                        <ContentPresenter Content="{TemplateBinding RightContent}" />

                                        <Button x:Name="PART_MinimizeButton" Width="40"
                                                Style="{StaticResource WindowButton}">
                                            <ct:Icon Kind="WindowMinimize"
                                                     Size="10"
                                                     Foreground="{DynamicResource Foreground.Muted}" />
                                        </Button>

                                        <Button x:Name="PART_MaximizeButton" Width="40"
                                                Style="{StaticResource WindowButton}">
                                            <ct:Icon x:Name="PART_MaximizeIcon"
                                                     Kind="WindowMaximize"
                                                     Size="10"
                                                     Foreground="{DynamicResource Foreground.Muted}" />
                                        </Button>

                                        <Button x:Name="PART_CloseButton" Width="40"
                                                Style="{StaticResource WindowCloseButton}">
                                            <ct:Icon x:Name="PART_CloseIcon"
                                                     Kind="WindowClose"
                                                     Size="10"
                                                     Foreground="{DynamicResource Foreground.Muted}" />
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <AdornerDecorator Grid.Row="1">
                                <ContentPresenter />
                            </AdornerDecorator>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Icon" Value="{x:Null}">
                            <Setter TargetName="PART_Icon" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="HasSubtitle" Value="True">
                            <Setter TargetName="PART_Separator" Property="Visibility" Value="Visible" />
                            <Setter TargetName="PART_Subtitle" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger SourceName="PART_CloseButton" Property="IsMouseOver" Value="True">
                            <Setter TargetName="PART_CloseIcon" Property="Foreground" Value="White" />
                        </Trigger>
                        <Trigger SourceName="PART_CloseButton" Property="IsPressed" Value="True">
                            <Setter TargetName="PART_CloseIcon" Property="Foreground" Value="White" />
                        </Trigger>
                        <Trigger Property="WindowState" Value="Maximized">
                            <Setter TargetName="PART_Root" Property="BorderThickness" Value="0" />
                            <Setter TargetName="PART_Root" Property="Padding" Value="{DynamicResource Spacing.M}" />
                            <Setter TargetName="PART_MaximizeIcon" Property="Kind" Value="WindowRestore" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>