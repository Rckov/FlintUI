<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style TargetType="{x:Type GridSplitter}">
        <Setter Property="Background" Value="{DynamicResource Border}" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type GridSplitter}">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}">
                        <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <Ellipse x:Name="D1" Width="3" Height="3" Fill="{DynamicResource Foreground.Muted}" Margin="0,1.5" />
                            <Ellipse x:Name="D2" Width="3" Height="3" Fill="{DynamicResource Foreground.Muted}" Margin="0,1.5" />
                            <Ellipse x:Name="D3" Width="3" Height="3" Fill="{DynamicResource Foreground.Muted}" Margin="0,1.5" />
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Accent.Dim}" />
                            <Setter TargetName="D1" Property="Fill" Value="{DynamicResource Accent}" />
                            <Setter TargetName="D2" Property="Fill" Value="{DynamicResource Accent}" />
                            <Setter TargetName="D3" Property="Fill" Value="{DynamicResource Accent}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>