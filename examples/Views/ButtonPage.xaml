<UserControl x:Class="FlintUI.Example.Views.ButtonPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:c="clr-namespace:FlintUI.Example.Controls"
             xmlns:demo="clr-namespace:FlintUI.Example"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ct="clr-namespace:FlintUI.Controls;assembly=FlintUI">
    <c:ExampleView Code="{x:Static demo:Snippets.Button}">
        <StackPanel Margin="{DynamicResource Spacing.L}" MaxWidth="720" HorizontalAlignment="Left">
            <TextBlock Text="Button"
                       FontSize="{DynamicResource FontSize.XL}"
                       FontWeight="{DynamicResource FontWeight.SemiBold}" />
            <TextBlock Text="An action in four intents."
                       Foreground="{DynamicResource Foreground.Muted}"
                       Margin="{DynamicResource Spacing.S.Top}" />

            <TextBlock Text="Intents"
                       FontWeight="{DynamicResource FontWeight.Medium}"
                       Margin="{DynamicResource Spacing.L.Top}" />
            <StackPanel Orientation="Horizontal" Margin="{DynamicResource Spacing.M.Top}">
                <ct:Button Content="Default" Margin="{DynamicResource Spacing.M.Right}" />
                <ct:Button Content="Accent" ButtonKind="Accent" Margin="{DynamicResource Spacing.M.Right}" />
                <ct:Button Content="Danger" ButtonKind="Danger" Margin="{DynamicResource Spacing.M.Right}" />
                <ct:Button Content="Ghost" ButtonKind="Ghost" />
            </StackPanel>

            <TextBlock Text="With icon"
                       FontWeight="{DynamicResource FontWeight.Medium}"
                       Margin="{DynamicResource Spacing.L.Top}" />
            <StackPanel Orientation="Horizontal" Margin="{DynamicResource Spacing.M.Top}">
                <ct:Button Content="New item" Icon="Plus" ButtonKind="Accent"
                           Margin="{DynamicResource Spacing.M.Right}" />
                <ct:Button Content="Save" Icon="Save" Margin="{DynamicResource Spacing.M.Right}" />
                <ct:Button Content="Delete" Icon="Trash" ButtonKind="Danger" />
            </StackPanel>

            <TextBlock Text="Icon only"
                       FontWeight="{DynamicResource FontWeight.Medium}"
                       Margin="{DynamicResource Spacing.L.Top}" />
            <StackPanel Orientation="Horizontal" Margin="{DynamicResource Spacing.M.Top}">
                <ct:Button Icon="Search" Margin="{DynamicResource Spacing.M.Right}" />
                <ct:Button Icon="Heart" ButtonKind="Accent" Margin="{DynamicResource Spacing.M.Right}" />
                <ct:Button Icon="MoreHorizontal" ButtonKind="Ghost" />
            </StackPanel>

            <TextBlock Text="Disabled"
                       FontWeight="{DynamicResource FontWeight.Medium}"
                       Margin="{DynamicResource Spacing.L.Top}" />
            <StackPanel Orientation="Horizontal" Margin="{DynamicResource Spacing.M.Top}">
                <ct:Button Content="Accent" ButtonKind="Accent" IsEnabled="False"
                           Margin="{DynamicResource Spacing.M.Right}" />
                <ct:Button Content="Default" IsEnabled="False" />
            </StackPanel>
        </StackPanel>
    </c:ExampleView>
</UserControl>