<Page x:Class="FlintUI.Example.Views.FrameDemoHomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:ct="clr-namespace:FlintUI.Controls;assembly=FlintUI"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent">
    <StackPanel Margin="{DynamicResource Spacing.L}" VerticalAlignment="Center">

        <StackPanel Orientation="Horizontal">
            <ct:Icon Kind="Home" Size="16" Foreground="{DynamicResource Accent}"
                     VerticalAlignment="Center" Margin="{DynamicResource Spacing.S.Right}" />
            <TextBlock Text="Dashboard"
                       FontSize="{DynamicResource FontSize.L}"
                       FontWeight="{DynamicResource FontWeight.SemiBold}" />
        </StackPanel>

        <UniformGrid Columns="3" Margin="{DynamicResource Spacing.M.Top}">
            <Border Background="{DynamicResource PanelBackground}"
                    BorderBrush="{DynamicResource Border}" BorderThickness="1"
                    CornerRadius="{DynamicResource Radius.S}" Padding="12,10"
                    Margin="{DynamicResource Spacing.S.Right}">
                <StackPanel>
                    <ct:Icon Kind="FileText" Size="14" Foreground="{DynamicResource Accent}"
                             HorizontalAlignment="Left" Margin="{DynamicResource Spacing.S.Bottom}" />
                    <TextBlock Text="42" FontSize="{DynamicResource FontSize.L}"
                               FontWeight="{DynamicResource FontWeight.SemiBold}" />
                    <TextBlock Text="Total" FontSize="{DynamicResource FontSize.S}"
                               Foreground="{DynamicResource Foreground.Muted}" />
                </StackPanel>
            </Border>
            <Border Background="{DynamicResource PanelBackground}"
                    BorderBrush="{DynamicResource Border}" BorderThickness="1"
                    CornerRadius="{DynamicResource Radius.S}" Padding="12,10"
                    Margin="{DynamicResource Spacing.S.Horizontal}">
                <StackPanel>
                    <ct:Icon Kind="CheckCircle" Size="14" Foreground="{DynamicResource Success}"
                             HorizontalAlignment="Left" Margin="{DynamicResource Spacing.S.Bottom}" />
                    <TextBlock Text="35" FontSize="{DynamicResource FontSize.L}"
                               FontWeight="{DynamicResource FontWeight.SemiBold}" />
                    <TextBlock Text="Done" FontSize="{DynamicResource FontSize.S}"
                               Foreground="{DynamicResource Foreground.Muted}" />
                </StackPanel>
            </Border>
            <Border Background="{DynamicResource PanelBackground}"
                    BorderBrush="{DynamicResource Border}" BorderThickness="1"
                    CornerRadius="{DynamicResource Radius.S}" Padding="12,10"
                    Margin="{DynamicResource Spacing.S.Left}">
                <StackPanel>
                    <ct:Icon Kind="Clock" Size="14" Foreground="{DynamicResource Warning}"
                             HorizontalAlignment="Left" Margin="{DynamicResource Spacing.S.Bottom}" />
                    <TextBlock Text="7" FontSize="{DynamicResource FontSize.L}"
                               FontWeight="{DynamicResource FontWeight.SemiBold}" />
                    <TextBlock Text="In progress" FontSize="{DynamicResource FontSize.S}"
                               Foreground="{DynamicResource Foreground.Muted}" />
                </StackPanel>
            </Border>
        </UniformGrid>

        <Grid Margin="{DynamicResource Spacing.M.Top}">
            <TextBlock Text="Completion" FontSize="{DynamicResource FontSize.S}"
                       Foreground="{DynamicResource Foreground.Muted}" />
            <TextBlock Text="83%" FontSize="{DynamicResource FontSize.S}"
                       Foreground="{DynamicResource Foreground.Muted}"
                       HorizontalAlignment="Right" />
        </Grid>
        <ProgressBar Value="83" Height="6" Margin="{DynamicResource Spacing.S.Top}" />

    </StackPanel>
</Page>