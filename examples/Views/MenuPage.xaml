<UserControl x:Class="FlintUI.Example.Views.MenuPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:c="clr-namespace:FlintUI.Example.Controls"
             xmlns:demo="clr-namespace:FlintUI.Example"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ct="clr-namespace:FlintUI.Controls;assembly=FlintUI">
    <c:ExampleView Code="{x:Static demo:Snippets.Menu}">
        <StackPanel Margin="{DynamicResource Spacing.L}" MaxWidth="720" HorizontalAlignment="Left">
            <TextBlock Text="Menu"
                       FontSize="{DynamicResource FontSize.XL}"
                       FontWeight="{DynamicResource FontWeight.SemiBold}" />
            <TextBlock Text="A menu bar and a right-click context menu."
                       Foreground="{DynamicResource Foreground.Muted}"
                       Margin="{DynamicResource Spacing.S.Top}" />

            <TextBlock Text="Menu bar" 
                       FontWeight="{DynamicResource FontWeight.Medium}"
                       Margin="{DynamicResource Spacing.L.Top}" />
            <Menu HorizontalAlignment="Left" Margin="{DynamicResource Spacing.M.Top}">
                <MenuItem Header="File">
                    <MenuItem Header="New">
                        <MenuItem.Icon>
                            <ct:Icon Kind="FilePlus" Size="14" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Open">
                        <MenuItem.Icon>
                            <ct:Icon Kind="Folder" Size="14" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator />
                    <MenuItem Header="Exit" />
                </MenuItem>
                <MenuItem Header="Edit">
                    <MenuItem Header="Undo" />
                    <MenuItem Header="Redo" />
                </MenuItem>
            </Menu>

            <TextBlock Text="Context menu" 
                       FontWeight="{DynamicResource FontWeight.Medium}"
                       Margin="{DynamicResource Spacing.L.Top}" />
            <Border Width="320"
                    Height="64"
                    Background="{DynamicResource Background}"
                    BorderBrush="{DynamicResource Border}"
                    BorderThickness="1"
                    CornerRadius="{DynamicResource Radius.S}"
                    Margin="{DynamicResource Spacing.M.Top}">
                <TextBlock Text="Right-click here for a menu"
                           Foreground="{DynamicResource Foreground.Muted}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
                <Border.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Cut">
                            <MenuItem.Icon>
                                <ct:Icon Kind="Scissors" Size="14" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="Copy">
                            <MenuItem.Icon>
                                <ct:Icon Kind="Copy" Size="14" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="Paste">
                            <MenuItem.Icon>
                                <ct:Icon Kind="Clipboard" Size="14" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <Separator />
                        <MenuItem Header="Delete">
                            <MenuItem.Icon>
                                <ct:Icon Kind="Trash" Size="14" />
                            </MenuItem.Icon>
                        </MenuItem>
                    </ContextMenu>
                </Border.ContextMenu>
            </Border>
        </StackPanel>
    </c:ExampleView>
</UserControl>