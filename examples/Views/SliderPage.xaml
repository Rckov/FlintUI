<UserControl x:Class="FlintUI.Example.Views.SliderPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:c="clr-namespace:FlintUI.Example.Controls"
             xmlns:demo="clr-namespace:FlintUI.Example"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <c:ExampleView Code="{x:Static demo:Snippets.Slider}">
        <StackPanel Margin="{DynamicResource Spacing.L}" MaxWidth="720" HorizontalAlignment="Left">
            <TextBlock Text="Slider"
                       FontSize="{DynamicResource FontSize.XL}"
                       FontWeight="{DynamicResource FontWeight.SemiBold}" />
            <TextBlock Text="Pick a value from a range by dragging."
                       Foreground="{DynamicResource Foreground.Muted}"
                       Margin="{DynamicResource Spacing.S.Top}" />

            <TextBlock Text="Default" FontWeight="{DynamicResource FontWeight.Medium}"
                       Margin="{DynamicResource Spacing.L.Top}" />
            <Slider Width="320" Minimum="0" Maximum="100" Value="60"
                    Margin="{DynamicResource Spacing.M.Top}" />

            <TextBlock Text="With ticks" FontWeight="{DynamicResource FontWeight.Medium}"
                       Margin="{DynamicResource Spacing.L.Top}" />
            <Slider Width="320" Minimum="0" Maximum="10" Value="4"
                    TickFrequency="1" TickPlacement="BottomRight" IsSnapToTickEnabled="True"
                    Margin="{DynamicResource Spacing.M.Top}" />

            <TextBlock Text="Disabled" FontWeight="{DynamicResource FontWeight.Medium}"
                       Margin="{DynamicResource Spacing.L.Top}" />
            <Slider Width="320" Minimum="0" Maximum="100" Value="30" IsEnabled="False"
                    Margin="{DynamicResource Spacing.M.Top}" />
        </StackPanel>
    </c:ExampleView>
</UserControl>