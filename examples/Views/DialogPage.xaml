<UserControl x:Class="FlintUI.Example.Views.DialogPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:c="clr-namespace:FlintUI.Example.Controls"
             xmlns:demo="clr-namespace:FlintUI.Example"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ct="clr-namespace:FlintUI.Controls;assembly=FlintUI"
             xmlns:vm="clr-namespace:FlintUI.Example.ViewModels">
    <UserControl.DataContext>
        <vm:DialogViewModel />
    </UserControl.DataContext>
    <c:ExampleView Code="{x:Static demo:Snippets.Dialog}">
        <StackPanel Margin="{DynamicResource Spacing.L}" MaxWidth="720" HorizontalAlignment="Left">
            <TextBlock Text="Dialog"
                       FontSize="{DynamicResource FontSize.XL}"
                       FontWeight="{DynamicResource FontWeight.SemiBold}" />
            <TextBlock Text="A modal message box with an icon and buttons."
                       Foreground="{DynamicResource Foreground.Muted}"
                       Margin="{DynamicResource Spacing.S.Top}" />

            <StackPanel Orientation="Horizontal" Margin="{DynamicResource Spacing.L.Top}">
                <ct:Button Content="Info" Icon="Info" Command="{Binding InfoCommand}"
                           Margin="{DynamicResource Spacing.M.Right}" />
                <ct:Button Content="Success" Icon="CheckCircle" Command="{Binding SuccessCommand}"
                           Margin="{DynamicResource Spacing.M.Right}" />
                <ct:Button Content="Confirm" Icon="HelpCircle" ButtonKind="Accent" Command="{Binding ConfirmCommand}"
                           Margin="{DynamicResource Spacing.M.Right}" />
                <ct:Button Content="Error" Icon="XCircle" ButtonKind="Danger" Command="{Binding ErrorCommand}" />
            </StackPanel>
        </StackPanel>
    </c:ExampleView>
</UserControl>