<UserControl x:Class="FlintUI.Example.Views.BadgePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:c="clr-namespace:FlintUI.Example.Controls"
             xmlns:demo="clr-namespace:FlintUI.Example"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ct="clr-namespace:FlintUI.Controls;assembly=FlintUI">
    <c:ExampleView Code="{x:Static demo:Snippets.Badge}">
        <StackPanel Margin="{DynamicResource Spacing.L}" MaxWidth="720" HorizontalAlignment="Left">
            <TextBlock Text="Badge"
                       FontSize="{DynamicResource FontSize.XL}"
                       FontWeight="{DynamicResource FontWeight.SemiBold}" />
            <TextBlock Text="A small label for status or counts."
                       Foreground="{DynamicResource Foreground.Muted}"
                       Margin="{DynamicResource Spacing.S.Top}" />

            <TextBlock Text="Types" 
                       FontWeight="{DynamicResource FontWeight.Medium}"
                       Margin="{DynamicResource Spacing.L.Top}" />
            <StackPanel Orientation="Horizontal" Margin="{DynamicResource Spacing.M.Top}">
                <ct:Badge Content="Default" Margin="{DynamicResource Spacing.M.Right}" />
                <ct:Badge Content="Accent" BadgeType="Accent" Margin="{DynamicResource Spacing.M.Right}" />
                <ct:Badge Content="Success" BadgeType="Success" Margin="{DynamicResource Spacing.M.Right}" />
                <ct:Badge Content="Warning" BadgeType="Warning" Margin="{DynamicResource Spacing.M.Right}" />
                <ct:Badge Content="Danger" BadgeType="Danger" />
            </StackPanel>

            <TextBlock Text="Next to text" 
                       FontWeight="{DynamicResource FontWeight.Medium}"
                       Margin="{DynamicResource Spacing.L.Top}" />
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="{DynamicResource Spacing.M.Top}">
                <TextBlock Text="Build status" VerticalAlignment="Center" Margin="{DynamicResource Spacing.M.Right}" />
                <ct:Badge Content="Passing" BadgeType="Success" />
            </StackPanel>
        </StackPanel>
    </c:ExampleView>
</UserControl>