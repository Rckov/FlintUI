<UserControl x:Class="FlintUI.Example.Views.FeedbackPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ct="clr-namespace:FlintUI.Controls;assembly=FlintUI">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="{DynamicResource Spacing.L}">
            <StackPanel Margin="{DynamicResource Spacing.L.Bottom}">
                <TextBlock Text="Feedback"
                           FontSize="{DynamicResource FontSize.XL}"
                           FontWeight="{DynamicResource FontWeight.SemiBold}" />
                <TextBlock Text="Dialogs, progress bars, and spinners that show what's happening."
                           Foreground="{DynamicResource Foreground.Muted}"
                           Margin="{DynamicResource Spacing.S.Top}" />
            </StackPanel>

            <GroupBox Header="Dialogs" Margin="{DynamicResource Spacing.L.Bottom}">
                <StackPanel Orientation="Horizontal">
                    <ct:Button Content="Info" Icon="Info" Click="OnInfo"
                               Margin="{DynamicResource Spacing.M.Right}" />
                    <ct:Button Content="Success" Icon="CheckCircle" Click="OnSuccess"
                               Margin="{DynamicResource Spacing.M.Right}" />
                    <ct:Button Content="Confirm" Icon="HelpCircle" ButtonKind="Accent" Click="OnConfirm"
                               Margin="{DynamicResource Spacing.M.Right}" />
                    <ct:Button Content="Error" Icon="XCircle" ButtonKind="Danger" Click="OnError" />
                </StackPanel>
            </GroupBox>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <GroupBox Header="Progress bar">
                    <StackPanel>
                        <StackPanel Margin="{DynamicResource Spacing.M.Bottom}">
                            <TextBlock Text="35%" FontSize="{DynamicResource FontSize.S}"
                                       Foreground="{DynamicResource Foreground.Muted}"
                                       Margin="{DynamicResource Spacing.S.Bottom}" />
                            <ProgressBar Value="35" Height="6" />
                        </StackPanel>
                        <StackPanel Margin="{DynamicResource Spacing.M.Bottom}">
                            <TextBlock Text="80%" FontSize="{DynamicResource FontSize.S}"
                                       Foreground="{DynamicResource Foreground.Muted}"
                                       Margin="{DynamicResource Spacing.S.Bottom}" />
                            <ProgressBar Value="80" Height="6" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Indeterminate" FontSize="{DynamicResource FontSize.S}"
                                       Foreground="{DynamicResource Foreground.Muted}"
                                       Margin="{DynamicResource Spacing.S.Bottom}" />
                            <ProgressBar IsIndeterminate="True" Height="6" />
                        </StackPanel>
                    </StackPanel>
                </GroupBox>

                <GroupBox Grid.Column="1" Header="Spinner &amp; tooltip" Margin="{DynamicResource Spacing.L.Left}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="{DynamicResource Spacing.L.Bottom}">
                            <ct:Spinner Width="20" Height="20" VerticalAlignment="Center"
                                        Margin="{DynamicResource Spacing.L.Right}" />
                            <ct:Spinner Width="28" Height="28" VerticalAlignment="Center"
                                        Margin="{DynamicResource Spacing.L.Right}" />
                            <ct:Spinner Width="36" Height="36" VerticalAlignment="Center" />
                        </StackPanel>
                        <ct:Button Content="Hover for a tooltip"
                                   ToolTip="Tooltips look like this"
                                   HorizontalAlignment="Left" />
                    </StackPanel>
                </GroupBox>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
