<UserControl x:Class="FlintUI.Example.Views.ToolTipPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:c="clr-namespace:FlintUI.Example.Controls"
             xmlns:demo="clr-namespace:FlintUI.Example"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ct="clr-namespace:FlintUI.Controls;assembly=FlintUI">
    <c:ExampleView Code="{x:Static demo:Snippets.ToolTip}">
        <StackPanel Margin="{DynamicResource Spacing.L}" MaxWidth="720" HorizontalAlignment="Left">
            <TextBlock Text="ToolTip"
                       FontSize="{DynamicResource FontSize.XL}"
                       FontWeight="{DynamicResource FontWeight.SemiBold}" />
            <TextBlock Text="A hint that appears on hover."
                       Foreground="{DynamicResource Foreground.Muted}"
                       Margin="{DynamicResource Spacing.S.Top}" />

            <StackPanel Orientation="Horizontal" Margin="{DynamicResource Spacing.L.Top}">
                <ct:Button Content="Hover over me" 
                           ToolTip="A short, helpful hint"
                           Margin="{DynamicResource Spacing.M.Right}" />
                <TextBlock Text="Or this text" 
                           VerticalAlignment="Center"
                           ToolTip="Tooltips work on any element">
                    <TextBlock.TextDecorations>
                        <TextDecoration Location="Underline" />
                    </TextBlock.TextDecorations>
                </TextBlock>
            </StackPanel>
        </StackPanel>
    </c:ExampleView>
</UserControl>