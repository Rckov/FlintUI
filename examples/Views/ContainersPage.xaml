<UserControl x:Class="FlintUI.Example.Views.ContainersPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ct="clr-namespace:FlintUI.Controls;assembly=FlintUI">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="{DynamicResource Spacing.L}">
            <StackPanel Margin="{DynamicResource Spacing.L.Bottom}">
                <TextBlock Text="Containers"
                           FontSize="{DynamicResource FontSize.XL}"
                           FontWeight="{DynamicResource FontWeight.SemiBold}" />
                <TextBlock Text="Panels that group content or hold commands."
                           Foreground="{DynamicResource Foreground.Muted}"
                           Margin="{DynamicResource Spacing.S.Top}" />
            </StackPanel>

            <GroupBox Header="Tab control" Margin="{DynamicResource Spacing.L.Bottom}">
                <ct:TabControl CloseButton="True" MinHeight="120">
                    <ct:TabItem Header="Overview" CanClose="False">
                        <TextBlock Text="This tab is pinned, so it has no close button."
                                   Foreground="{DynamicResource Foreground.Muted}"
                                   Margin="{DynamicResource Spacing.M.Top}" />
                    </ct:TabItem>
                    <ct:TabItem Header="Activity">
                        <TextBlock Text="Recent activity for the workspace."
                                   Foreground="{DynamicResource Foreground.Muted}"
                                   Margin="{DynamicResource Spacing.M.Top}" />
                    </ct:TabItem>
                    <ct:TabItem Header="Settings">
                        <TextBlock Text="Workspace preferences."
                                   Foreground="{DynamicResource Foreground.Muted}"
                                   Margin="{DynamicResource Spacing.M.Top}" />
                    </ct:TabItem>
                </ct:TabControl>
            </GroupBox>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <GroupBox Header="Expander">
                    <StackPanel>
                        <Expander Header="Shipping address" IsExpanded="True"
                                  Margin="{DynamicResource Spacing.M.Bottom}">
                            <TextBlock Text="1 Market St, San Francisco, CA"
                                       Foreground="{DynamicResource Foreground.Muted}"
                                       Margin="{DynamicResource Spacing.M.Top}" />
                        </Expander>
                        <Expander Header="Billing address">
                            <TextBlock Text="Same as shipping address."
                                       Foreground="{DynamicResource Foreground.Muted}"
                                       Margin="{DynamicResource Spacing.M.Top}" />
                        </Expander>
                    </StackPanel>
                </GroupBox>

                <GroupBox Grid.Column="1" Header="Menus" Margin="{DynamicResource Spacing.L.Left}">
                    <StackPanel>
                        <Menu Margin="{DynamicResource Spacing.L.Bottom}">
                            <MenuItem Header="File">
                                <MenuItem Header="New">
                                    <MenuItem.Icon>
                                        <ct:Icon Kind="FilePlus" Size="14" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="Open">
                                    <MenuItem.Icon>
                                        <ct:Icon Kind="Folder" Size="14" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <Separator />
                                <MenuItem Header="Exit" />
                            </MenuItem>
                            <MenuItem Header="Edit">
                                <MenuItem Header="Undo" />
                                <MenuItem Header="Redo" />
                            </MenuItem>
                        </Menu>

                        <Border Background="{DynamicResource Background}"
                                BorderBrush="{DynamicResource Border}"
                                BorderThickness="1"
                                CornerRadius="{DynamicResource Radius.S}"
                                Height="56">
                            <TextBlock Text="Right-click here for a menu"
                                       Foreground="{DynamicResource Foreground.Muted}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                            <Border.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Cut">
                                        <MenuItem.Icon>
                                            <ct:Icon Kind="Scissors" Size="14" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="Copy">
                                        <MenuItem.Icon>
                                            <ct:Icon Kind="Copy" Size="14" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="Paste">
                                        <MenuItem.Icon>
                                            <ct:Icon Kind="Clipboard" Size="14" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <Separator />
                                    <MenuItem Header="Delete">
                                        <MenuItem.Icon>
                                            <ct:Icon Kind="Trash" Size="14" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                </ContextMenu>
                            </Border.ContextMenu>
                        </Border>
                    </StackPanel>
                </GroupBox>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
