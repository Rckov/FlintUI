<Page x:Class="FlintUI.Example.Views.FrameDemoSettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:ct="clr-namespace:FlintUI.Controls;assembly=FlintUI"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent">
    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">

        <TextBlock Text="Notifications"
                   FontSize="{DynamicResource FontSize.L}"
                   FontWeight="{DynamicResource FontWeight.SemiBold}"
                   Margin="{DynamicResource Spacing.L.Bottom}" />

        <ct:ToggleSwitch Content="Email notifications" IsChecked="True"
                         Margin="{DynamicResource Spacing.M.Bottom}" />
        <ct:ToggleSwitch Content="Push notifications" />

    </StackPanel>
</Page>