<UserControl x:Class="FlintUI.Example.Views.InputsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ct="clr-namespace:FlintUI.Controls;assembly=FlintUI">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="{DynamicResource Spacing.L}">
            <StackPanel Margin="{DynamicResource Spacing.L.Bottom}">
                <TextBlock Text="Inputs"
                           FontSize="{DynamicResource FontSize.XL}"
                           FontWeight="{DynamicResource FontWeight.SemiBold}" />
                <TextBlock Text="Fields for text, numbers, dates, and picking from a list."
                           Foreground="{DynamicResource Foreground.Muted}"
                           Margin="{DynamicResource Spacing.S.Top}" />
            </StackPanel>

            <Grid Margin="{DynamicResource Spacing.L.Bottom}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <GroupBox Header="Text">
                    <StackPanel>
                        <StackPanel Margin="{DynamicResource Spacing.M.Bottom}">
                            <TextBlock Text="Default" FontSize="{DynamicResource FontSize.S}"
                                       Foreground="{DynamicResource Foreground.Muted}"
                                       Margin="{DynamicResource Spacing.S.Bottom}" />
                            <ct:TextBox Placeholder="Type here" />
                        </StackPanel>
                        <StackPanel Margin="{DynamicResource Spacing.M.Bottom}">
                            <TextBlock Text="With icon" FontSize="{DynamicResource FontSize.S}"
                                       Foreground="{DynamicResource Foreground.Muted}"
                                       Margin="{DynamicResource Spacing.S.Bottom}" />
                            <ct:TextBox Placeholder="Search" IconKind="Search" />
                        </StackPanel>
                        <StackPanel Margin="{DynamicResource Spacing.M.Bottom}">
                            <TextBlock Text="Clearable" FontSize="{DynamicResource FontSize.S}"
                                       Foreground="{DynamicResource Foreground.Muted}"
                                       Margin="{DynamicResource Spacing.S.Bottom}" />
                            <ct:TextBox Text="Clear me" ClearButton="True" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Disabled" FontSize="{DynamicResource FontSize.S}"
                                       Foreground="{DynamicResource Foreground.Muted}"
                                       Margin="{DynamicResource Spacing.S.Bottom}" />
                            <ct:TextBox Text="Read only" IsEnabled="False" />
                        </StackPanel>
                    </StackPanel>
                </GroupBox>

                <GroupBox Grid.Column="1" Header="Password" Margin="{DynamicResource Spacing.L.Left}">
                    <StackPanel>
                        <StackPanel Margin="{DynamicResource Spacing.M.Bottom}">
                            <TextBlock Text="With reveal" FontSize="{DynamicResource FontSize.S}"
                                       Foreground="{DynamicResource Foreground.Muted}"
                                       Margin="{DynamicResource Spacing.S.Bottom}" />
                            <ct:PasswordBox Placeholder="Password" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="No reveal" FontSize="{DynamicResource FontSize.S}"
                                       Foreground="{DynamicResource Foreground.Muted}"
                                       Margin="{DynamicResource Spacing.S.Bottom}" />
                            <ct:PasswordBox Placeholder="Password" RevealButton="False" />
                        </StackPanel>
                    </StackPanel>
                </GroupBox>
            </Grid>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <GroupBox Header="Number">
                    <StackPanel>
                        <StackPanel Margin="{DynamicResource Spacing.M.Bottom}">
                            <TextBlock Text="Default" FontSize="{DynamicResource FontSize.S}"
                                       Foreground="{DynamicResource Foreground.Muted}"
                                       Margin="{DynamicResource Spacing.S.Bottom}" />
                            <ct:NumericUpDown Value="8" />
                        </StackPanel>
                        <StackPanel Margin="{DynamicResource Spacing.M.Bottom}">
                            <TextBlock Text="Range" FontSize="{DynamicResource FontSize.S}"
                                       Foreground="{DynamicResource Foreground.Muted}"
                                       Margin="{DynamicResource Spacing.S.Bottom}" />
                            <ct:NumericUpDown Value="25" Minimum="0" Maximum="100" Step="5" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Decimal" FontSize="{DynamicResource FontSize.S}"
                                       Foreground="{DynamicResource Foreground.Muted}"
                                       Margin="{DynamicResource Spacing.S.Bottom}" />
                            <ct:NumericUpDown Value="1.5" Step="0.1" StringFormat="0.0" />
                        </StackPanel>
                    </StackPanel>
                </GroupBox>

                <GroupBox Grid.Column="1" Header="Choice &amp; date" Margin="{DynamicResource Spacing.L.Left}">
                    <StackPanel>
                        <StackPanel Margin="{DynamicResource Spacing.M.Bottom}">
                            <TextBlock Text="ComboBox" FontSize="{DynamicResource FontSize.S}"
                                       Foreground="{DynamicResource Foreground.Muted}"
                                       Margin="{DynamicResource Spacing.S.Bottom}" />
                            <ComboBox SelectedIndex="0">
                                <ComboBoxItem Content="Low priority" />
                                <ComboBoxItem Content="Medium priority" />
                                <ComboBoxItem Content="High priority" />
                            </ComboBox>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="DatePicker" FontSize="{DynamicResource FontSize.S}"
                                       Foreground="{DynamicResource Foreground.Muted}"
                                       Margin="{DynamicResource Spacing.S.Bottom}" />
                            <DatePicker />
                        </StackPanel>
                    </StackPanel>
                </GroupBox>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
