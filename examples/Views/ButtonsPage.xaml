<UserControl x:Class="FlintUI.Example.Views.ButtonsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ct="clr-namespace:FlintUI.Controls;assembly=FlintUI">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="{DynamicResource Spacing.L}">
            <StackPanel Margin="{DynamicResource Spacing.L.Bottom}">
                <TextBlock Text="Buttons"
                           FontSize="{DynamicResource FontSize.XL}"
                           FontWeight="{DynamicResource FontWeight.SemiBold}" />
                <TextBlock Text="Four button styles, each with an optional icon."
                           Foreground="{DynamicResource Foreground.Muted}"
                           Margin="{DynamicResource Spacing.S.Top}" />
            </StackPanel>

            <GroupBox Header="Intents" Margin="{DynamicResource Spacing.L.Bottom}">
                <StackPanel Orientation="Horizontal">
                    <ct:Button Content="Default" Margin="{DynamicResource Spacing.M.Right}" />
                    <ct:Button Content="Accent" ButtonKind="Accent" Margin="{DynamicResource Spacing.M.Right}" />
                    <ct:Button Content="Danger" ButtonKind="Danger" Margin="{DynamicResource Spacing.M.Right}" />
                    <ct:Button Content="Ghost" ButtonKind="Ghost" />
                </StackPanel>
            </GroupBox>

            <GroupBox Header="With icon" Margin="{DynamicResource Spacing.L.Bottom}">
                <StackPanel Orientation="Horizontal">
                    <ct:Button Content="New item" Icon="Plus" ButtonKind="Accent"
                               Margin="{DynamicResource Spacing.M.Right}" />
                    <ct:Button Content="Save" Icon="Save" Margin="{DynamicResource Spacing.M.Right}" />
                    <ct:Button Content="Delete" Icon="Trash" ButtonKind="Danger"
                               Margin="{DynamicResource Spacing.M.Right}" />
                    <ct:Button Content="Settings" Icon="Settings" ButtonKind="Ghost" />
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Icon only" Margin="{DynamicResource Spacing.L.Bottom}">
                <StackPanel Orientation="Horizontal">
                    <ct:Button Icon="Search" Margin="{DynamicResource Spacing.M.Right}" />
                    <ct:Button Icon="Heart" ButtonKind="Accent" Margin="{DynamicResource Spacing.M.Right}" />
                    <ct:Button Icon="MoreHorizontal" ButtonKind="Ghost" />
                </StackPanel>
            </GroupBox>

            <GroupBox Header="States" Margin="{DynamicResource Spacing.L.Bottom}">
                <StackPanel Orientation="Horizontal">
                    <ct:Button Content="Enabled" ButtonKind="Accent" Margin="{DynamicResource Spacing.M.Right}" />
                    <ct:Button Content="Disabled" ButtonKind="Accent" IsEnabled="False"
                               Margin="{DynamicResource Spacing.M.Right}" />
                    <ct:Button Content="Disabled" IsEnabled="False" />
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Badges">
                <StackPanel Orientation="Horizontal">
                    <ct:Badge Content="Default" Margin="{DynamicResource Spacing.M.Right}" />
                    <ct:Badge Content="Accent" BadgeType="Accent" Margin="{DynamicResource Spacing.M.Right}" />
                    <ct:Badge Content="Success" BadgeType="Success" Margin="{DynamicResource Spacing.M.Right}" />
                    <ct:Badge Content="Warning" BadgeType="Warning" Margin="{DynamicResource Spacing.M.Right}" />
                    <ct:Badge Content="Danger" BadgeType="Danger" />
                </StackPanel>
            </GroupBox>
        </StackPanel>
    </ScrollViewer>
</UserControl>
