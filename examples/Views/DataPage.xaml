<UserControl x:Class="FlintUI.Example.Views.DataPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ct="clr-namespace:FlintUI.Controls;assembly=FlintUI">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="{DynamicResource Spacing.L}">
            <StackPanel Margin="{DynamicResource Spacing.L.Bottom}">
                <TextBlock Text="Data"
                           FontSize="{DynamicResource FontSize.XL}"
                           FontWeight="{DynamicResource FontWeight.SemiBold}" />
                <TextBlock Text="A grid, a list, and a tree."
                           Foreground="{DynamicResource Foreground.Muted}"
                           Margin="{DynamicResource Spacing.S.Top}" />
            </StackPanel>

            <GroupBox Header="Data grid" Margin="{DynamicResource Spacing.L.Bottom}">
                <DataGrid ItemsSource="{Binding People}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          Height="208">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                        <DataGridTextColumn Header="Role" Binding="{Binding Role}" Width="Auto" />
                        <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="2*" />
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <GroupBox Header="List box">
                    <ListBox Height="176" BorderThickness="0">
                        <ListBoxItem Content="Inbox" IsSelected="True" />
                        <ListBoxItem Content="Starred" />
                        <ListBoxItem Content="Sent" />
                        <ListBoxItem Content="Drafts" />
                        <ListBoxItem Content="Archive" />
                    </ListBox>
                </GroupBox>

                <GroupBox Grid.Column="1" Header="Tree view" Margin="{DynamicResource Spacing.L.Left}">
                    <TreeView Height="176" BorderThickness="0">
                        <TreeViewItem Header="Project" IsExpanded="True">
                            <TreeViewItem Header="src" IsExpanded="True">
                                <TreeViewItem Header="Controls" />
                                <TreeViewItem Header="Styles" />
                            </TreeViewItem>
                            <TreeViewItem Header="examples">
                                <TreeViewItem Header="Views" />
                            </TreeViewItem>
                            <TreeViewItem Header="README.md" />
                        </TreeViewItem>
                    </TreeView>
                </GroupBox>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
