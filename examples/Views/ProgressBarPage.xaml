<UserControl x:Class="FlintUI.Example.Views.ProgressBarPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:c="clr-namespace:FlintUI.Example.Controls"
             xmlns:demo="clr-namespace:FlintUI.Example"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <c:ExampleView Code="{x:Static demo:Snippets.ProgressBar}">
        <StackPanel Margin="{DynamicResource Spacing.L}" MaxWidth="720" HorizontalAlignment="Left">
            <TextBlock Text="ProgressBar"
                       FontSize="{DynamicResource FontSize.XL}"
                       FontWeight="{DynamicResource FontWeight.SemiBold}" />
            <TextBlock Text="Shows how far along a task is."
                       Foreground="{DynamicResource Foreground.Muted}"
                       Margin="{DynamicResource Spacing.S.Top}" />

            <TextBlock Text="35%"
                       FontWeight="{DynamicResource FontWeight.Medium}"
                       Margin="{DynamicResource Spacing.L.Top}" />
            <ProgressBar Width="360" Height="6" Value="35"
                         Margin="{DynamicResource Spacing.M.Top}" />

            <TextBlock Text="80%"
                       FontWeight="{DynamicResource FontWeight.Medium}"
                       Margin="{DynamicResource Spacing.L.Top}" />
            <ProgressBar Width="360" Height="6" Value="80"
                         Margin="{DynamicResource Spacing.M.Top}" />

            <TextBlock Text="Indeterminate"
                       FontWeight="{DynamicResource FontWeight.Medium}"
                       Margin="{DynamicResource Spacing.L.Top}" />
            <ProgressBar Width="360" Height="6" IsIndeterminate="True"
                         Margin="{DynamicResource Spacing.M.Top}" />
        </StackPanel>
    </c:ExampleView>
</UserControl>