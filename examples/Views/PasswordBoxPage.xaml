<UserControl x:Class="FlintUI.Example.Views.PasswordBoxPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:c="clr-namespace:FlintUI.Example.Controls"
             xmlns:demo="clr-namespace:FlintUI.Example"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ct="clr-namespace:FlintUI.Controls;assembly=FlintUI">
    <c:ExampleView Code="{x:Static demo:Snippets.PasswordBox}">
        <StackPanel Margin="{DynamicResource Spacing.L}" MaxWidth="720" HorizontalAlignment="Left">
            <TextBlock Text="PasswordBox"
                       FontSize="{DynamicResource FontSize.XL}"
                       FontWeight="{DynamicResource FontWeight.SemiBold}" />
            <TextBlock Text="A password field with an optional reveal button."
                       Foreground="{DynamicResource Foreground.Muted}"
                       Margin="{DynamicResource Spacing.S.Top}" />

            <TextBlock Text="With reveal" 
                       FontWeight="{DynamicResource FontWeight.Medium}"
                       Margin="{DynamicResource Spacing.L.Top}" />
            <ct:PasswordBox Width="280" Placeholder="Password"
                            Margin="{DynamicResource Spacing.M.Top}" />

            <TextBlock Text="No reveal" 
                       FontWeight="{DynamicResource FontWeight.Medium}"
                       Margin="{DynamicResource Spacing.L.Top}" />
            <ct:PasswordBox Width="280" 
                            Placeholder="Password" 
                            RevealButton="False"
                            Margin="{DynamicResource Spacing.M.Top}" />

            <TextBlock Text="Disabled" 
                       FontWeight="{DynamicResource FontWeight.Medium}"
                       Margin="{DynamicResource Spacing.L.Top}" />
            <ct:PasswordBox Width="280" Placeholder="Password" IsEnabled="False" Margin="{DynamicResource Spacing.M.Top}" />
        </StackPanel>
    </c:ExampleView>
</UserControl>