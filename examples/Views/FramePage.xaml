<UserControl x:Class="FlintUI.Example.Views.FramePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:c="clr-namespace:FlintUI.Example.Controls"
             xmlns:ct="clr-namespace:FlintUI.Controls;assembly=FlintUI"
             xmlns:demo="clr-namespace:FlintUI.Example"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <c:ExampleView Code="{x:Static demo:Snippets.Frame}">
        <StackPanel Margin="{DynamicResource Spacing.L}" MaxWidth="720" HorizontalAlignment="Left">
            <TextBlock Text="Frame"
                       FontSize="{DynamicResource FontSize.XL}"
                       FontWeight="{DynamicResource FontWeight.SemiBold}" />
            <TextBlock Text="A navigation host that keeps a history of visited pages and lets you move between them."
                       Foreground="{DynamicResource Foreground.Muted}"
                       Margin="{DynamicResource Spacing.S.Top}" />

            <Border Width="460"
                    Margin="{DynamicResource Spacing.L.Top}"
                    BorderBrush="{DynamicResource Border}"
                    BorderThickness="1"
                    CornerRadius="{DynamicResource Radius.S}"
                    HorizontalAlignment="Left">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="280" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            BorderBrush="{DynamicResource Border}"
                            BorderThickness="0,0,0,1"
                            Padding="{StaticResource Spacing.S}">
                        <Grid>
                            <StackPanel Orientation="Horizontal">
                                <ct:Button Icon="ChevronLeft"
                                           ButtonKind="Ghost"
                                           Command="{Binding GoBackCommand}"
                                           ToolTip="Back" />
                                <ct:Button Icon="ChevronRight"
                                           ButtonKind="Ghost"
                                           Command="{Binding GoForwardCommand}"
                                           ToolTip="Forward" />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <ct:Button Content="Home" Icon="Home"
                                           ButtonKind="Ghost"
                                           Command="{Binding NavigateHomeCommand}" />
                                <ct:Button Content="Profile" Icon="User"
                                           ButtonKind="Ghost"
                                           Command="{Binding NavigateProfileCommand}" />
                                <ct:Button Content="Settings" Icon="Settings"
                                           ButtonKind="Ghost"
                                           Command="{Binding NavigateSettingsCommand}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Frame x:Name="DemoFrame"
                           Grid.Row="1"
                           BorderThickness="0" />
                </Grid>
            </Border>
        </StackPanel>
    </c:ExampleView>
</UserControl>