<ct:Window x:Class="FlintUI.Example.Views.ShellView"
           xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
           xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
           xmlns:ct="clr-namespace:FlintUI.Controls;assembly=FlintUI"
           Title="FlintUI"
           Subtitle="Component Gallery"
           Width="1200"
           Height="820"
           MinWidth="980"
           MinHeight="620"
           WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Background="{DynamicResource PanelBackground}"
                BorderBrush="{DynamicResource Border}"
                BorderThickness="0,0,1,0">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top"
                           Text="COMPONENTS"
                           FontSize="{DynamicResource FontSize.X}"
                           FontWeight="{DynamicResource FontWeight.SemiBold}"
                           Foreground="{DynamicResource Foreground.Muted}"
                           Margin="{DynamicResource Spacing.L}" />

                <ListBox x:Name="Nav"
                         Margin="{DynamicResource Spacing.M.Horizontal}"
                         Background="Transparent"
                         BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <ct:Icon Kind="{Binding Icon}"
                                         Margin="{DynamicResource Spacing.M.Right}"
                                         VerticalAlignment="Center"
                                         Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" />
                                <TextBlock Text="{Binding Title}"
                                           VerticalAlignment="Center"
                                           FontSize="{DynamicResource FontSize.M}" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <ContentControl Grid.Column="1"
                        Content="{Binding SelectedItem.View, ElementName=Nav}" />
    </Grid>
</ct:Window>
