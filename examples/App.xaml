<Application x:Class="FlintUI.Example.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="clr-namespace:FlintUI;assembly=FlintUI"
             xmlns:c="clr-namespace:FlintUI.Example.Controls"
             xmlns:avalon="http://icsharpcode.net/sharpdevelop/avalonedit"
             StartupUri="Views/ShellView.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:FlintResources />
            </ResourceDictionary.MergedDictionaries>

            <Style TargetType="{x:Type c:ExampleView}">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type c:ExampleView}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                                    <ContentPresenter />
                                </ScrollViewer>

                                <Border Grid.Row="1"
                                        Background="{DynamicResource PanelBackground}"
                                        BorderBrush="{DynamicResource Border}"
                                        BorderThickness="0,1,0,0"
                                        Padding="{DynamicResource Spacing.M}">
                                    <Expander Header="XAML" IsExpanded="True">
                                        <Border Background="{DynamicResource ControlBackground}"
                                                BorderBrush="{DynamicResource Border}"
                                                BorderThickness="1"
                                                CornerRadius="{DynamicResource Radius.S}"
                                                Margin="{DynamicResource Spacing.S.Top}">
                                            <avalon:TextEditor x:Name="PART_Editor"
                                                               IsReadOnly="True"
                                                               SyntaxHighlighting="XML"
                                                               FontFamily="{DynamicResource Font.Mono}"
                                                               FontSize="{DynamicResource FontSize.S}"
                                                               Background="Transparent"
                                                               Padding="8"
                                                               MaxHeight="200"
                                                               HorizontalScrollBarVisibility="Auto"
                                                               VerticalScrollBarVisibility="Auto" />
                                        </Border>
                                    </Expander>
                                </Border>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>